{
  "appId": "com.pos.app",
  "appName": "POS System",
  "webDir": "build",
  "bundledWebRuntime": false,
  "server": {
    "androidScheme": "https",
    "cleartext": true
  },
  "android": {
    "allowMixedContent": true,
    "captureInput": true,
    "webContentsDebuggingEnabled": false,
    "windowSoftInputMode": "adjustResize"
  },
  "plugins": {
    "PushNotifications": {
      "presentationOptions": ["badge", "sound", "alert"]
    },
    "StatusBar": {
      "style": "dark",
      "backgroundColor": "#1C1A27",
      "overlaysWebView": false
    }
  }
}
